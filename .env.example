# App
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=1
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Throttler (rate limiting)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=govt_project
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-super-secret-refresh
JWT_REFRESH_EXPIRES_IN=7d
